{
	"name": "tinybase-supabase",
	"version": "0.3.0",
	"description": "Browser-only offline-first TinyBase persistence and Supabase synchronization.",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"sideEffects": false,
	"engines": {
		"node": ">=22.14.0"
	},
	"packageManager": "pnpm@10.23.0",
	"scripts": {
		"build": "tsup",
		"changeset": "changeset",
		"check": "pnpm run format:check && pnpm run lint && pnpm run typecheck",
		"docs:build": "vitepress build docs",
		"docs:dev": "vitepress dev docs",
		"docs:preview": "vitepress preview docs",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint .",
		"test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
		"test:e2e": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand tests/e2e",
		"test:integration": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand --detectOpenHandles tests/integration",
		"test:unit": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand tests/unit",
		"test:watch": "jest --watch",
		"typecheck": "tsc --noEmit",
		"version": "changeset version"
	},
	"peerDependencies": {
		"@supabase/supabase-js": "^2.0.0",
		"tinybase": "^8.0.0"
	},
	"dependencies": {
		"idb": "^8.0.3",
		"yjs": "13.6.31"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@changesets/cli": "^2.29.8",
		"@jest/globals": "^30.2.0",
		"@supabase/supabase-js": "^2.110.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^22.0.0",
		"fake-indexeddb": "^6.2.5",
		"jest": "^30.2.0",
		"playwright": "^1.58.0",
		"tinybase": "^8.0.0",
		"ts-jest": "^29.4.5",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitepress": "^1.6.4",
		"vue": "^3.5.0"
	},
	"keywords": [
		"tinybase",
		"supabase",
		"offline-first",
		"indexeddb",
		"persistence"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/andrewmunsell/tinybase-supabase.git"
	},
	"bugs": {
		"url": "https://github.com/andrewmunsell/tinybase-supabase/issues"
	},
	"homepage": "https://github.com/andrewmunsell/tinybase-supabase#readme",
	"publishConfig": {
		"access": "public"
	}
}
