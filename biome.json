{
	"$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended"
		}
	},
	"overrides": [
		{
			"includes": ["*.yml", "*.yaml"],
			"formatter": {
				"indentStyle": "space",
				"indentWidth": 2
			}
		}
	],
	"files": {
		"includes": ["**", "!dist", "!coverage", "!node_modules", "!pnpm-lock.yaml"]
	}
}
